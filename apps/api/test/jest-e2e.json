{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "moduleNameMapper": {
    "^@teamwork/types$": "<rootDir>/test/shims/types.ts",
    "^@teamwork/validation$": "<rootDir>/test/shims/validation.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
